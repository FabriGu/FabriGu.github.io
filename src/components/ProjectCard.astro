---
import type { EnrichedRepo } from '../lib/github';
import { getLanguageColor } from '../lib/github';

interface Props {
  repo: EnrichedRepo;
  size?: 'normal' | 'large';
  index?: number;
}

const { repo, size = 'normal', index = 0 } = Astro.props;
const isLarge = size === 'large';
---

<a
  href={repo.url}
  target="_blank"
  rel="noopener noreferrer"
  data-reveal
  data-reveal-delay={String(Math.min(index, 4))}
  class:list={[
    'card block group transition-all duration-300 ease-out hover:-translate-y-1',
    isLarge && 'md:col-span-2',
  ]}
>
  <div class="flex items-start justify-between mb-3">
    <span class="label">{repo.category || repo.language || 'project'}</span>
    {repo.stars > 0 && (
      <span class="text-text-dim text-xs flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        {repo.stars}
      </span>
    )}
  </div>

  <h3 class:list={[
    'card-title font-semibold text-accent-soft transition-colors duration-300',
    isLarge ? 'text-xl' : 'text-base',
  ]}>
    {repo.name}
  </h3>

  <p class:list={[
    'mt-2 text-text-muted leading-relaxed',
    isLarge ? 'text-sm' : 'text-sm',
  ]}>
    {repo.tagline || repo.description || 'No description'}
  </p>

  <div class="mt-4 flex items-center gap-3">
    {repo.language && (
      <span class="flex items-center gap-1.5 text-xs text-text-dim">
        <span class="w-2 h-2 rounded-full" style={`background-color: ${getLanguageColor(repo.language)}`}></span>
        {repo.language}
      </span>
    )}
  </div>
</a>
