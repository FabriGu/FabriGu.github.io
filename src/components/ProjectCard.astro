---
import type { EnrichedRepo } from '../lib/github';
import { getLanguageColor } from '../lib/github';

interface Props {
  repo: EnrichedRepo;
  size?: 'normal' | 'large';
}

const { repo, size = 'normal' } = Astro.props;
const isLarge = size === 'large';
---

<a
  href={repo.url}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    isLarge ? 'card-highlight' : 'card',
    'block group',
    isLarge && 'sm:col-span-2',
  ]}
>
  <div class="flex items-start justify-between mb-3">
    <div class="flex items-center gap-2">
      {repo.emoji && <span class="text-xl">{repo.emoji}</span>}
      <h3 class:list={[
        'font-semibold text-purple-100 group-hover:text-white transition-colors',
        isLarge ? 'text-xl' : 'text-base',
      ]}>
        {repo.name}
      </h3>
    </div>
    {repo.stars > 0 && (
      <span class="text-purple-400 text-sm flex items-center gap-1">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        {repo.stars}
      </span>
    )}
  </div>

  <p class:list={[
    'text-purple-300 mb-4 leading-relaxed',
    isLarge ? 'text-base' : 'text-sm',
  ]}>
    {repo.tagline || repo.description || 'No description'}
  </p>

  <div class="flex items-center gap-3 flex-wrap">
    {repo.language && (
      <span class="flex items-center gap-1.5 text-xs text-purple-400">
        <span class="w-2.5 h-2.5 rounded-full" style={`background-color: ${getLanguageColor(repo.language)}`}></span>
        {repo.language}
      </span>
    )}
    {repo.category && (
      <span class="badge">{repo.category}</span>
    )}
  </div>
</a>
