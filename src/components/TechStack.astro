---
const tools = [
  { name: 'Python', icon: 'python' },
  { name: 'JavaScript', icon: 'js' },
  { name: 'TypeScript', icon: 'ts' },
  { name: 'Svelte', icon: 'svelte' },
  { name: 'React', icon: 'react' },
  { name: 'TensorFlow', icon: 'tensorflow' },
  { name: 'Arduino', icon: 'arduino' },
  { name: 'C++', icon: 'cpp' },
  { name: 'Swift', icon: 'swift' },
  { name: 'Node.js', icon: 'nodejs' },
  { name: 'Docker', icon: 'docker' },
  { name: 'Figma', icon: 'figma' },
];
---

<section class="max-w-6xl mx-auto px-6 py-16">
  <h2 class="text-2xl font-bold gradient-text mb-2">tech & tools</h2>
  <p class="text-purple-400 mb-8">languages, frameworks, and things i use to build</p>

  <div class="flex flex-wrap gap-3 justify-center">
    {tools.map(tool => (
      <div class="card !p-3 flex items-center gap-2 text-sm text-purple-200">
        <img
          src={`https://cdn.simpleicons.org/${tool.icon}/C084FC`}
          alt={tool.name}
          width="18"
          height="18"
          loading="lazy"
        />
        {tool.name}
      </div>
    ))}
  </div>
</section>
