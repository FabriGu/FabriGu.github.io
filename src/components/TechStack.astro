---
const skills = [
  { area: 'AI / ML', items: 'AI Agents, LLM APIs, Stable Diffusion, CLIP, Whisper, MediaPipe, OpenCV' },
  { area: 'Programming', items: 'Python, JavaScript, TypeScript, C++, C, Java, Node.js' },
  { area: 'Creative Coding', items: 'TouchDesigner, THREE.js, p5.js, Processing, GLSL' },
  { area: 'Hardware', items: 'Arduino, ESP32, Raspberry Pi, OAK-D' },
  { area: 'Fabrication', items: 'Laser cutting, CNC, 3D printing, machine embroidery' },
  { area: 'Design', items: 'Fusion 360, Figma, Blender, Unity' },
];
---

<section class="max-w-5xl mx-auto px-6 py-24">
  <p data-reveal class="label mb-3">tools</p>
  <h2 data-reveal data-reveal-delay="1" class="text-3xl font-bold text-accent-soft tracking-tight mb-10">
    what i work with
  </h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {skills.map((skill, i) => (
      <div data-reveal data-reveal-delay={String(Math.min(i, 4))} class="card">
        <h3 class="text-sm font-semibold text-accent mb-2">{skill.area}</h3>
        <p class="text-sm text-text-muted leading-relaxed">{skill.items}</p>
      </div>
    ))}
  </div>
</section>
