---

<section class="relative overflow-hidden py-24 sm:py-32">
  <!-- Gradient background orbs -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-500/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-purple-700/15 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/2 left-1/2 w-64 h-64 bg-purple-400/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 text-center">
    <p class="text-purple-400 text-sm font-mono mb-4 tracking-wider">hey, i'm</p>
    <h1 class="text-5xl sm:text-7xl font-bold mb-6">
      <span class="gradient-text">Fabrizio Guccione</span>
    </h1>
    <p class="text-xl sm:text-2xl text-purple-200 mb-4 max-w-2xl mx-auto leading-relaxed">
      creative technologist making things that <br class="hidden sm:block" />
      probably shouldn't exist yet
    </p>
    <p class="text-purple-400 mb-10">
      NYU ITP · AI + hardware + interactive art
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="/projects" class="px-6 py-3 bg-purple-600 hover:bg-purple-500 text-white rounded-full font-medium transition-colors">
        see my work
      </a>
      <a href="https://github.com/FabriGu" target="_blank" class="px-6 py-3 border border-purple-500/50 hover:border-purple-400 text-purple-200 rounded-full font-medium transition-colors">
        github
      </a>
    </div>
  </div>
</section>
