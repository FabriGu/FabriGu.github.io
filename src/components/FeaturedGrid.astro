---
import type { EnrichedRepo } from '../lib/github';
import ProjectCard from './ProjectCard.astro';

interface Props {
  repos: EnrichedRepo[];
}

const { repos } = Astro.props;
const highlighted = repos.filter(r => r.highlight);
---

<section class="max-w-6xl mx-auto px-6 py-16">
  <h2 class="text-2xl font-bold gradient-text mb-2">featured projects</h2>
  <p class="text-purple-400 mb-8">things i've built that i'm proud of</p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {highlighted.map((repo, i) => (
      <ProjectCard repo={repo} size={i < 2 ? 'large' : 'normal'} />
    ))}
  </div>

  <div class="text-center mt-10">
    <a href="/projects" class="text-purple-400 hover:text-purple-200 transition-colors text-sm font-medium">
      view all projects &rarr;
    </a>
  </div>
</section>
