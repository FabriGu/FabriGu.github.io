---
import type { EnrichedRepo } from '../lib/github';
import ProjectCard from './ProjectCard.astro';

interface Props {
  repos: EnrichedRepo[];
}

const { repos } = Astro.props;
const highlighted = repos.filter(r => r.highlight);
---

<section class="max-w-5xl mx-auto px-6 py-24">
  <p data-reveal class="label mb-3">selected work</p>
  <h2 data-reveal data-reveal-delay="1" class="text-3xl font-bold text-accent-soft tracking-tight mb-10">
    things i've built
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    {highlighted.map((repo, i) => (
      <ProjectCard repo={repo} size={i < 2 ? 'large' : 'normal'} index={i} />
    ))}
  </div>

  <div data-reveal class="text-center mt-12">
    <a href="/projects" class="link-underline text-sm">
      all projects &rarr;
    </a>
  </div>
</section>
