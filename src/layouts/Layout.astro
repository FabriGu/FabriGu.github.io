---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  toc?: { id: string; text: string; level: number }[];
}

const { title, description = "Fabrizio Guccione — Embedded Intelligence Designer.", toc = [] } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <!-- Header -->
    <header class="wiki-header">
      <a href="/" class="wiki-logo">
        <div>
          <span class="wiki-logo-text">Fabripedia</span>
          <span class="wiki-logo-sub">the personal encyclopedia</span>
        </div>
      </a>
      <div class="wiki-header-links">
        <a href="https://guccione.work" target="_blank" rel="noopener">Portfolio</a>
        <a href="https://github.com/FabriGu" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.linkedin.com/in/fabriziog/" target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </header>

    <!-- Page grid -->
    <div class="wiki-page">

      <!-- Left sidebar: Table of Contents -->
      <aside class="wiki-sidebar">
        {toc.length > 0 && (
          <div>
            <div class="toc-heading">Contents</div>
            <ul class="toc-list">
              <li><a href="#">(Top)</a></li>
              {toc.map(item => (
                <li>
                  {item.level === 2 ? (
                    <a href={`#${item.id}`}>{item.text}</a>
                  ) : (
                    <ul class="toc-sub"><li><a href={`#${item.id}`}>{item.text}</a></li></ul>
                  )}
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>

      <!-- Content area -->
      <div class="wiki-content">
        <slot />
      </div>
    </div>

    <!-- Footer -->
    <footer class="wiki-footer">
      <div>This page was last edited on {new Date().toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' })}.</div>
      <div class="wiki-footer-links">
        <a href="https://guccione.work">Portfolio</a>
        <a href="https://github.com/FabriGu">GitHub</a>
        <a href="https://www.linkedin.com/in/fabriziog/">LinkedIn</a>
        <a href="https://x.com/fabricated_it">X</a>
        <a href="https://www.instagram.com/fabricated.it/">Instagram</a>
      </div>
    </footer>

    <!-- Scroll spy for TOC highlighting -->
    <script>
      function initScrollSpy() {
        const links = document.querySelectorAll('.toc-list a');
        const sections = Array.from(links).map(link => {
          const id = link.getAttribute('href')?.replace('#', '');
          return id ? document.getElementById(id) : null;
        }).filter(Boolean);

        function onScroll() {
          let current = '';
          for (const section of sections) {
            if (section && section.getBoundingClientRect().top <= 100) {
              current = section.id;
            }
          }
          links.forEach(link => {
            link.classList.toggle('active', link.getAttribute('href') === `#${current}`);
          });
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
      initScrollSpy();
      document.addEventListener('astro:after-swap', initScrollSpy);
    </script>
  </body>
</html>
