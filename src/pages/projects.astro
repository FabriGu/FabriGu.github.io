---
import Layout from '../layouts/Layout.astro';
import { getRepos, enrichRepos, parseFeaturedYaml, getLanguageColor } from '../lib/github';
import { readFileSync } from 'fs';
import { join } from 'path';

const yamlText = readFileSync(join(process.cwd(), 'src/data/featured.yml'), 'utf-8');
const featured = parseFeaturedYaml(yamlText);
const repos = await getRepos();
const enriched = enrichRepos(repos, featured);
const languages = [...new Set(enriched.map(r => r.language).filter(Boolean))].sort() as string[];
---

<Layout title="All Projects — Fabripedia">
  <h1 class="font-serif text-3xl font-bold text-white tracking-tight mb-1" data-reveal>
    List of projects
  </h1>
  <p class="text-sm text-[var(--wiki-text-dim)] italic mb-6" data-reveal>
    From Fabripedia — {enriched.length} original repositories, forks excluded, auto-updated from GitHub
  </p>

  <div class="toc mb-6" data-reveal>
    <div class="toc-title">Filter by language</div>
    <div class="flex flex-wrap gap-2 text-sm" id="filters">
      <button class="wiki-link font-semibold cursor-pointer" data-filter="all">All</button>
      {languages.map(lang => (
        <button class="wiki-link cursor-pointer opacity-70 hover:opacity-100 transition-opacity" data-filter={lang}>
          {lang}
        </button>
      ))}
    </div>
  </div>

  <table class="wiki-table" data-reveal>
    <thead>
      <tr>
        <th>Project</th>
        <th>Description</th>
        <th>Language</th>
        <th>Category</th>
      </tr>
    </thead>
    <tbody id="project-tbody">
      {enriched.map((repo) => (
        <tr class="project-row" data-language={repo.language || ''}>
          <td>
            <a href={repo.url} class="wiki-link font-medium" target="_blank" rel="noopener">{repo.name}</a>
            {repo.highlight && <span class="text-xs text-[var(--wiki-accent)] ml-1">★</span>}
          </td>
          <td class="text-[var(--wiki-text-muted)]">{repo.tagline || repo.description || '—'}</td>
          <td>
            {repo.language && (
              <span class="flex items-center gap-1.5 text-[var(--wiki-text-dim)]">
                <span class="inline-block w-2 h-2 rounded-full" style={`background: ${getLanguageColor(repo.language)}`}></span>
                {repo.language}
              </span>
            )}
          </td>
          <td class="text-[var(--wiki-text-dim)]">{repo.category || '—'}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <div class="wiki-categories" data-reveal>
    <strong>Categories:</strong>
    {languages.map(lang => (
      <a href="#" class="cursor-pointer" data-filter-link={lang}>{lang}</a>
    ))}
  </div>

  <script>
    const rows = document.querySelectorAll('.project-row');
    const buttons = document.querySelectorAll('[data-filter]');

    function filterBy(lang: string) {
      rows.forEach(row => {
        const el = row as HTMLElement;
        el.style.display = (lang === 'all' || el.dataset.language === lang) ? '' : 'none';
      });
      buttons.forEach(btn => {
        const b = btn as HTMLElement;
        if (b.dataset.filter === lang) {
          b.classList.add('font-semibold');
          b.classList.remove('opacity-70');
        } else {
          b.classList.remove('font-semibold');
          b.classList.add('opacity-70');
        }
      });
    }

    document.getElementById('filters')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-filter]') as HTMLElement;
      if (btn?.dataset.filter) filterBy(btn.dataset.filter);
    });

    document.querySelectorAll('[data-filter-link]').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        filterBy((link as HTMLElement).dataset.filterLink || 'all');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });
  </script>
</Layout>
