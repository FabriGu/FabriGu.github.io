---
import Layout from '../layouts/Layout.astro';
import { getRepos, enrichRepos, parseFeaturedYaml, getLanguageColor } from '../lib/github';
import { readFileSync } from 'fs';
import { join } from 'path';

const yamlText = readFileSync(join(process.cwd(), 'src/data/featured.yml'), 'utf-8');
const featured = parseFeaturedYaml(yamlText);
const repos = await getRepos();
const enriched = enrichRepos(repos, featured);
const languages = [...new Set(enriched.map(r => r.language).filter(Boolean))].sort() as string[];

const toc = [
  { id: 'complete-list', text: 'Complete list', level: 2 },
  ...languages.slice(0, 8).map(l => ({ id: `lang-${l}`, text: l, level: 3 })),
  { id: 'categories', text: 'Categories', level: 2 },
];
---

<Layout title="List of projects — Fabripedia" toc={toc}>

  <div class="wiki-tabs">
    <div class="wiki-tabs-left">
      <a href="/" class="wiki-tab">Article</a>
      <a href="/projects" class="wiki-tab active">All projects</a>
    </div>
    <div class="wiki-tabs-right">
      <a href="https://github.com/FabriGu?tab=repositories" class="wiki-tab" target="_blank" rel="noopener">View on GitHub</a>
    </div>
  </div>

  <h1 class="wiki-title">List of projects by Fabrizio Guccione</h1>
  <p class="wiki-subtitle">From Fabripedia, the personal encyclopedia</p>

  <div class="hatnote">
    This is an auto-generated list of {enriched.length} original repositories. Forks are excluded.
    Data is refreshed daily from the <a href="https://docs.github.com/rest">GitHub API</a>.
  </div>

  <p>
    The following is a list of public software projects by <a href="/">Fabrizio Guccione</a>,
    maintained on <a href="https://github.com/FabriGu">GitHub</a>. Projects marked with ★ are featured works.
  </p>

  <h2 id="complete-list" class="wiki-h2">Complete list</h2>

  <table class="wikitable">
    <tbody>
      <tr>
        <th style="width:25%">Project</th>
        <th>Description</th>
        <th style="width:12%">Language</th>
        <th style="width:12%">Category</th>
      </tr>
      {enriched.map((repo) => (
        <tr>
          <td>
            <a href={repo.url} target="_blank" rel="noopener">{repo.name}</a>
            {repo.highlight && <span style="color:#7c3aed;margin-left:0.25em;" title="Featured">★</span>}
          </td>
          <td>{repo.tagline || repo.description || '—'}</td>
          <td>
            {repo.language && (
              <span style={`display:inline-flex;align-items:center;gap:4px;`}>
                <span style={`width:8px;height:8px;border-radius:50%;background:${getLanguageColor(repo.language)};display:inline-block;`}></span>
                {repo.language}
              </span>
            )}
          </td>
          <td>{repo.category || '—'}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <div id="categories" class="wiki-categories">
    <b>Categories</b>:
    {languages.map((lang, i) => (
      <><a href={`https://github.com/FabriGu?tab=repositories&q=&type=&language=${lang.toLowerCase()}`} target="_blank" rel="noopener">{lang}</a>{i < languages.length - 1 ? ' · ' : ''}</>
    ))}
  </div>

</Layout>
