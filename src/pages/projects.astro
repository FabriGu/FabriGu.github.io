---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getRepos, enrichRepos, parseFeaturedYaml } from '../lib/github';
import { readFileSync } from 'fs';
import { join } from 'path';

const yamlText = readFileSync(join(process.cwd(), 'src/data/featured.yml'), 'utf-8');
const featured = parseFeaturedYaml(yamlText);
const repos = await getRepos();
const enriched = enrichRepos(repos, featured);

const languages = [...new Set(enriched.map(r => r.language).filter(Boolean))].sort() as string[];
---

<Layout title="Projects — Fabrizio Guccione" description="All projects by Fabrizio Guccione. AI, interactive installations, hardware, creative coding.">
  <section class="max-w-5xl mx-auto px-6 py-24">
    <p data-reveal class="label mb-3">all work</p>
    <h1 data-reveal data-reveal-delay="1" class="text-4xl font-bold text-accent-soft tracking-tight mb-2">
      projects
    </h1>
    <p data-reveal data-reveal-delay="2" class="text-text-dim text-sm mb-10">
      {enriched.length} original repos · auto-updated from GitHub · forks excluded
    </p>

    <!-- Filter chips -->
    <div data-reveal data-reveal-delay="3" class="flex flex-wrap gap-2 mb-10" id="filters">
      <button class="text-xs font-mono px-3 py-1.5 rounded-lg bg-accent-muted/20 border border-accent-muted/40 text-accent-soft cursor-pointer transition-all duration-200" data-filter="all">all</button>
      <button class="text-xs font-mono px-3 py-1.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-dim cursor-pointer hover:text-text-muted hover:border-white/[0.12] transition-all duration-200" data-filter="featured">featured</button>
      {languages.slice(0, 6).map(lang => (
        <button class="text-xs font-mono px-3 py-1.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-dim cursor-pointer hover:text-text-muted hover:border-white/[0.12] transition-all duration-200" data-filter={`lang:${lang}`}>{lang}</button>
      ))}
    </div>

    <!-- Project grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="project-grid">
      {enriched.map((repo, i) => (
        <div
          class="project-item"
          data-featured={repo.featured ? 'true' : 'false'}
          data-language={repo.language || ''}
        >
          <ProjectCard repo={repo} index={Math.min(i, 4)} />
        </div>
      ))}
    </div>
  </section>

  <script>
    const filters = document.getElementById('filters');
    const items = document.querySelectorAll('.project-item');
    const activeClass = ['bg-accent-muted/20', 'border-accent-muted/40', 'text-accent-soft'];
    const inactiveClass = ['bg-white/[0.03]', 'border-white/[0.06]', 'text-text-dim'];

    filters?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (!btn) return;

      filters.querySelectorAll('button').forEach(b => {
        activeClass.forEach(c => b.classList.remove(c));
        inactiveClass.forEach(c => b.classList.add(c));
      });
      inactiveClass.forEach(c => btn.classList.remove(c));
      activeClass.forEach(c => btn.classList.add(c));

      const filter = btn.dataset.filter;

      items.forEach(item => {
        const el = item as HTMLElement;
        let show = true;

        if (filter === 'featured') {
          show = el.dataset.featured === 'true';
        } else if (filter?.startsWith('lang:')) {
          show = el.dataset.language === filter.replace('lang:', '');
        }

        el.style.display = show ? '' : 'none';
      });
    });
  </script>
</Layout>
