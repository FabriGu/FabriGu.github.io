---
import Layout from '../layouts/Layout.astro';
import { getRepos, enrichRepos, parseFeaturedYaml } from '../lib/github';
import { readFileSync } from 'fs';
import { join } from 'path';

const yamlText = readFileSync(join(process.cwd(), 'src/data/featured.yml'), 'utf-8');
const featured = parseFeaturedYaml(yamlText);
const repos = await getRepos();
const enriched = enrichRepos(repos, featured);
const highlighted = enriched.filter(r => r.highlight);
const repoCount = enriched.length;
---

<Layout title="Fabrizio Guccione — Fabripedia">

  <!-- Article title -->
  <h1 class="font-serif text-4xl md:text-5xl font-bold text-white tracking-tight leading-[0.95] mb-1" data-reveal>
    Fabrizio Guccione
  </h1>
  <p class="text-sm text-[var(--wiki-text-dim)] mb-6 italic" data-reveal>
    From Fabripedia, the personal encyclopedia
  </p>

  <div class="hatnote" data-reveal>
    For the full portfolio, see <a href="https://guccione.work" class="wiki-link" target="_blank" rel="noopener">guccione.work</a>.
    For source code, see <a href="https://github.com/FabriGu" class="wiki-link" target="_blank" rel="noopener">GitHub</a>.
  </div>

  <!-- Infobox -->
  <div class="infobox" data-reveal>
    <div class="infobox-header">Fabrizio Guccione</div>
    <div class="infobox-image">
      <div class="w-full aspect-square bg-gradient-to-br from-[#7c3aed]/20 to-[#a78bfa]/10 rounded flex items-center justify-center">
        <span class="text-6xl font-serif font-bold text-[var(--wiki-accent)]">FG</span>
      </div>
    </div>
    <div class="infobox-row">
      <div class="infobox-label">Born</div>
      <div class="infobox-value">Italy</div>
    </div>
    <div class="infobox-row">
      <div class="infobox-label">Based in</div>
      <div class="infobox-value">Brooklyn, NY</div>
    </div>
    <div class="infobox-row">
      <div class="infobox-label">Education</div>
      <div class="infobox-value">NYU ITP (MPS '26)<br/>NYU (BA Psychology, CS minor)</div>
    </div>
    <div class="infobox-row">
      <div class="infobox-label">Known for</div>
      <div class="infobox-value">AI-driven interactive installations, speech-to-3D clothing, fabrication</div>
    </div>
    <div class="infobox-row">
      <div class="infobox-label">Title</div>
      <div class="infobox-value">Embedded Intelligence Designer</div>
    </div>
    <div class="infobox-row">
      <div class="infobox-label">Languages</div>
      <div class="infobox-value">Italian, English, Spanish</div>
    </div>
    <div class="infobox-row">
      <div class="infobox-label">Website</div>
      <div class="infobox-value"><a href="https://guccione.work" class="wiki-link" target="_blank" rel="noopener">guccione.work</a></div>
    </div>
  </div>

  <!-- Table of Contents -->
  <div class="toc" data-reveal>
    <div class="toc-title">Contents</div>
    <ol class="toc-list">
      <li><span class="toc-number">1</span><a href="#about">About</a></li>
      <li><span class="toc-number">2</span><a href="#notable-works">Notable works</a>
        <ul>
          {highlighted.map((r, i) => (
            <li><span class="toc-number">2.{i+1}</span><a href={`#${r.name}`}>{r.name}</a></li>
          ))}
        </ul>
      </li>
      <li><span class="toc-number">3</span><a href="#skills">Skills and tools</a></li>
      <li><span class="toc-number">4</span><a href="#career">Career</a></li>
      <li><span class="toc-number">5</span><a href="#education">Education</a></li>
      <li><span class="toc-number">6</span><a href="#stats">GitHub statistics</a></li>
      <li><span class="toc-number">7</span><a href="#reading">Reading list</a></li>
      <li><span class="toc-number">8</span><a href="#external-links">External links</a></li>
    </ol>
  </div>

  <!-- About -->
  <h2 id="about" class="wiki-heading font-serif text-2xl font-bold text-white" data-reveal>
    About <a href="https://github.com/FabriGu" class="wiki-edit" target="_blank">[github]</a>
  </h2>
  <p class="text-[var(--wiki-text)] leading-relaxed mb-4" data-reveal>
    <strong>Fabrizio Guccione</strong> is an Embedded Intelligence Designer focused on AI-driven interactive
    systems and generative pipelines. His work bridges machine learning, physical computing, and fabrication
    to create immersive experiences that live in physical space — not just on screens.
  </p>
  <p class="text-[var(--wiki-text)] leading-relaxed mb-4" data-reveal>
    He is an NYU ITP graduate with production experience across research labs, agencies, and fashion.
    He currently runs ITP's Fabrication Shop, where he trains 300+ students on laser cutting, CNC milling,
    3D printing, and machine embroidery. Previously he worked at McCann New York exploring generative AI
    in campaigns, and at ADEAM constructing garments from sketch to runway.
  </p>
  <p class="text-[var(--wiki-text)] leading-relaxed mb-4" data-reveal>
    His interests outside of work include playing guitar, cooking, and DJing.
  </p>

  <!-- Notable Works -->
  <h2 id="notable-works" class="wiki-heading font-serif text-2xl font-bold text-white" data-reveal>
    Notable works
  </h2>

  {highlighted.map((repo) => (
    <div data-reveal>
      <h3 id={repo.name} class="font-serif text-lg font-bold text-white mt-6 mb-2">
        {repo.name}
        <a href={repo.url} class="wiki-edit" target="_blank" rel="noopener">[src]</a>
      </h3>
      <p class="text-[var(--wiki-text)] leading-relaxed mb-2">
        {repo.tagline || repo.description}
      </p>
      <p class="text-sm text-[var(--wiki-text-dim)]">
        {repo.language && (<><span class="inline-block w-2 h-2 rounded-full mr-1" style={`background: ${repo.language === 'Python' ? '#3572A5' : repo.language === 'JavaScript' ? '#f1e05a' : repo.language === 'TypeScript' ? '#3178c6' : repo.language === 'C++' ? '#f34b7d' : repo.language === 'Svelte' ? '#ff3e00' : '#7c3aed'}`}></span>{repo.language} · </>)}
        {repo.category}
      </p>
    </div>
  ))}

  <p class="text-sm mt-6" data-reveal>
    <a href="/projects" class="wiki-link">See all {repoCount} projects →</a>
  </p>

  <!-- Skills -->
  <h2 id="skills" class="wiki-heading font-serif text-2xl font-bold text-white" data-reveal>
