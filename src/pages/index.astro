---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedGrid from '../components/FeaturedGrid.astro';
import TechStack from '../components/TechStack.astro';
import { getRepos, enrichRepos, parseFeaturedYaml } from '../lib/github';
import { readFileSync } from 'fs';
import { join } from 'path';

const yamlText = readFileSync(join(process.cwd(), 'src/data/featured.yml'), 'utf-8');
const featured = parseFeaturedYaml(yamlText);
const repos = await getRepos();
const enriched = enrichRepos(repos, featured);
---

<Layout title="Fabrizio Guccione — Embedded Intelligence Designer">
  <Hero />
  <FeaturedGrid repos={enriched} />
  <TechStack />

  <section class="max-w-5xl mx-auto px-6 py-24">
    <div data-reveal class="card max-w-xl mx-auto text-center">
      <p class="label mb-3">get in touch</p>
      <p class="text-text-muted text-sm leading-relaxed mb-6">
        Always interested in installations, AI systems, and weird fabrication problems.
      </p>
      <div class="flex gap-3 justify-center flex-wrap">
        <a href="https://www.linkedin.com/in/fabriziog/" target="_blank" rel="noopener" class="link-underline text-sm">linkedin</a>
        <span class="text-text-dim">·</span>
        <a href="https://x.com/fabricated_it" target="_blank" rel="noopener" class="link-underline text-sm">x</a>
        <span class="text-text-dim">·</span>
        <a href="https://www.instagram.com/fabricated.it/" target="_blank" rel="noopener" class="link-underline text-sm">instagram</a>
        <span class="text-text-dim">·</span>
        <a href="https://guccione.work" target="_blank" rel="noopener" class="link-underline text-sm">portfolio</a>
      </div>
    </div>
  </section>
</Layout>
