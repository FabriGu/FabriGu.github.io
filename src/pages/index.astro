---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedGrid from '../components/FeaturedGrid.astro';
import TechStack from '../components/TechStack.astro';
import { getRepos, enrichRepos } from '../lib/github';
import type { FeaturedRepo } from '../lib/github';
import { readFileSync } from 'fs';
import { join } from 'path';

// Load featured config
// Astro doesn't natively parse YAML in data files without a plugin,
// so we'll parse it manually
const yamlPath = join(process.cwd(), 'src/data/featured.yml');
const yamlText = readFileSync(yamlPath, 'utf-8');

function parseSimpleYaml(text: string): FeaturedRepo[] {
  const items: FeaturedRepo[] = [];
  let current: any = null;

  for (const line of text.split('\n')) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#')) continue;

    if (trimmed.startsWith('- repo:')) {
      if (current) items.push(current);
      current = { repo: trimmed.replace('- repo:', '').trim(), tagline: '', category: '', emoji: '', highlight: false };
    } else if (current && trimmed.startsWith('tagline:')) {
      current.tagline = trimmed.replace('tagline:', '').trim().replace(/^"|"$/g, '');
    } else if (current && trimmed.startsWith('category:')) {
      current.category = trimmed.replace('category:', '').trim().replace(/^"|"$/g, '');
    } else if (current && trimmed.startsWith('emoji:')) {
      current.emoji = trimmed.replace('emoji:', '').trim().replace(/^"|"$/g, '');
    } else if (current && trimmed.startsWith('highlight:')) {
      current.highlight = trimmed.replace('highlight:', '').trim() === 'true';
    }
  }
  if (current) items.push(current);
  return items;
}

const featured = parseSimpleYaml(yamlText);
const repos = await getRepos();
const enriched = enrichRepos(repos, featured);
---

<Layout title="Fabrizio Guccione — Creative Technologist">
  <Hero />
  <FeaturedGrid repos={enriched} />
  <TechStack />

  <section class="max-w-6xl mx-auto px-6 py-16 text-center">
    <div class="card max-w-2xl mx-auto">
      <h2 class="text-xl font-bold gradient-text mb-3">let's connect</h2>
      <p class="text-purple-300 mb-6 text-sm">
        always down to chat about creative tech, weird projects, or anything really.
      </p>
      <div class="flex gap-3 justify-center flex-wrap">
        <a href="https://www.linkedin.com/in/fabriziog/" target="_blank" class="badge hover:bg-purple-600/30 transition-colors">linkedin</a>
        <a href="https://x.com/fabricated_it" target="_blank" class="badge hover:bg-purple-600/30 transition-colors">x / twitter</a>
        <a href="https://www.instagram.com/fabricated.it/" target="_blank" class="badge hover:bg-purple-600/30 transition-colors">instagram</a>
        <a href="https://github.com/FabriGu" target="_blank" class="badge hover:bg-purple-600/30 transition-colors">github</a>
      </div>
    </div>
  </section>
</Layout>
