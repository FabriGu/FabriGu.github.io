---
import Layout from '../layouts/Layout.astro';
import { getRepos, enrichRepos, parseFeaturedYaml } from '../lib/github';
import { readFileSync } from 'fs';
import { join } from 'path';

const yamlText = readFileSync(join(process.cwd(), 'src/data/featured.yml'), 'utf-8');
const featured = parseFeaturedYaml(yamlText);
const repos = await getRepos();
const enriched = enrichRepos(repos, featured);
const highlighted = enriched.filter(r => r.highlight);
const repoCount = enriched.length;

const toc = [
  { id: 'about', text: 'About', level: 2 },
  { id: 'notable-works', text: 'Notable works', level: 2 },
  ...highlighted.map(r => ({ id: r.name, text: r.name, level: 3 })),
  { id: 'skills', text: 'Skills and tools', level: 2 },
  { id: 'career', text: 'Career', level: 2 },
  { id: 'education', text: 'Education', level: 2 },
  { id: 'github-statistics', text: 'GitHub statistics', level: 2 },
  { id: 'contribution-graph', text: 'Contribution graph', level: 3 },
  { id: 'reading-list', text: 'Reading list', level: 2 },
  { id: 'external-links', text: 'External links', level: 2 },
];
---

<Layout title="Fabrizio Guccione — Fabripedia" toc={toc}>

  <!-- Article tabs -->
  <div class="wiki-tabs">
    <div class="wiki-tabs-left">
      <a href="/" class="wiki-tab active">Article</a>
