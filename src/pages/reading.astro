---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

const yamlText = readFileSync(join(process.cwd(), 'src/data/reading-list.yml'), 'utf-8');

interface Book {
  isbn: string;
  title: string;
  author: string;
  status: string;
  coverUrl: string;
}

function parseBooks(text: string): Book[] {
  const items: any[] = [];
  let current: any = null;
  for (const line of text.split('\n')) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#')) continue;
    if (trimmed.startsWith('- isbn:')) {
      if (current) items.push(current);
      current = { isbn: trimmed.replace('- isbn:', '').trim().replace(/^"|"$/g, ''), title: '', author: '', status: 'read' };
    } else if (current && trimmed.startsWith('title:')) {
      current.title = trimmed.replace('title:', '').trim().replace(/^"|"$/g, '');
    } else if (current && trimmed.startsWith('author:')) {
      current.author = trimmed.replace('author:', '').trim().replace(/^"|"$/g, '');
    } else if (current && trimmed.startsWith('status:')) {
      current.status = trimmed.replace('status:', '').trim();
    }
  }
  if (current) items.push(current);
  return items.map(b => ({ ...b, coverUrl: `https://covers.openlibrary.org/b/isbn/${b.isbn}-M.jpg` }));
}

const books = parseBooks(yamlText);
const readBooks = books.filter(b => b.status === 'read');
const readingBooks = books.filter(b => b.status === 'reading');
const wantBooks = books.filter(b => b.status === 'want-to-read');

const toc = [
  ...(readingBooks.length > 0 ? [{ id: 'currently-reading', text: 'Currently reading', level: 2 }] : []),
  { id: 'read', text: 'Read', level: 2 },
  ...(wantBooks.length > 0 ? [{ id: 'want-to-read', text: 'Want to read', level: 2 }] : []),
  { id: 'see-also', text: 'See also', level: 2 },
];
---

<Layout title="Reading list — Fabripedia" toc={toc}>

  <div class="wiki-tabs">
    <div class="wiki-tabs-left">
      <a href="/" class="wiki-tab">Article</a>
      <a href="/reading" class="wiki-tab active">Reading list</a>
    </div>
    <div class="wiki-tabs-right">
      <a href="https://github.com/FabriGu/FabriGu.github.io/edit/main/src/data/reading-list.yml" class="wiki-tab" target="_blank" rel="noopener">Edit list</a>
    </div>
  </div>

  <h1 class="wiki-title">Fabrizio Guccione's reading list</h1>
  <p class="wiki-subtitle">From Fabripedia, the personal encyclopedia</p>

  <div class="hatnote">
    Book covers are sourced from <a href="https://openlibrary.org" target="_blank" rel="noopener">OpenLibrary</a>.
    To suggest a book, <a href="https://github.com/FabriGu/FabriGu.github.io/edit/main/src/data/reading-list.yml" target="_blank" rel="noopener">edit this list</a>.
  </div>

  <p>
    The following is a list of books that have shaped <a href="/">Fabrizio Guccione</a>'s thinking about
    design, intelligence, systems, and fabrication.
  </p>

  {readingBooks.length > 0 && (
    <>
      <h2 id="currently-reading" class="wiki-h2">Currently reading</h2>
      <table class="wikitable">
        <tbody>
          <tr><th style="width:70px">Cover</th><th>Title</th><th>Author</th></tr>
          {readingBooks.map(book => (
            <tr>
              <td><img src={book.coverUrl} alt={book.title} class="book-cover" loading="lazy" /></td>
              <td><b>{book.title}</b></td>
              <td>{book.author}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}

  <h2 id="read" class="wiki-h2">Read</h2>
  <table class="wikitable">
    <tbody>
      <tr><th style="width:70px">Cover</th><th>Title</th><th>Author</th><th style="width:120px">ISBN</th></tr>
      {readBooks.map(book => (
        <tr>
          <td><img src={book.coverUrl} alt={book.title} class="book-cover" loading="lazy" /></td>
          <td><b>{book.title}</b></td>
          <td>{book.author}</td>
          <td style="font-family:monospace;font-size:0.8em;color:var(--wiki-text-dim)">{book.isbn}</td>
        </tr>
      ))}
    </tbody>
  </table>

  {wantBooks.length > 0 && (
    <>
      <h2 id="want-to-read" class="wiki-h2">Want to read</h2>
      <table class="wikitable">
        <tbody>
          <tr><th style="width:70px">Cover</th><th>Title</th><th>Author</th></tr>
          {wantBooks.map(book => (
            <tr>
              <td><img src={book.coverUrl} alt={book.title} class="book-cover" loading="lazy" /></td>
              <td><b>{book.title}</b></td>
              <td>{book.author}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}

  <h2 id="see-also" class="wiki-h2">See also</h2>
  <ul>
    <li><a href="/">Fabrizio Guccione</a> — main article</li>
    <li><a href="/projects">List of projects</a> — all GitHub repositories</li>
  </ul>

  <div class="wiki-categories">
    <b>Categories</b>:
    <a href="/">Fabrizio Guccione</a> ·
    <a href="/reading">Reading lists</a> ·
    <a href="/projects">Projects</a>
  </div>

</Layout>
